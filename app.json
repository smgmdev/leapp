{
  "expo": {
    "name": "Chat",
    "slug": "lethal-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#111b21"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lethal.chat"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#111b21"
      },
      "package": "com.lethal.chat",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "updates": {
      "url": "https://u.expo.dev/lethal-app"
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    }
  }
}
